{
  "manifest_version": 3,
  "name": "Tab Chaos Analyzer",
  "version": "1.0.0",
  "description": "Analyze your browsing chaos with humor and actionable insights. Your digital productivity coach with personality.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "bookmarks"
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Tab Chaos Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}