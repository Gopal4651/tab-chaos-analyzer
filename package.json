{
  "name": "tab-chaos-analyzer",
  "version": "1.0.0",
  "description": "A diagnostic browser extension that analyzes tab chaos with humor and actionable insights",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
